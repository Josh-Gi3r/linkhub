# ── Core ──────────────────────────────────────────────────────────────────────
# A long random string used to sign session JWTs. Required, no default.
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# Port the server binds to (optional; defaults to 3000)
PORT=3000

# Your deployed URL (used for OG meta tags, QR codes, wallet pass URLs)
PUBLIC_BASE_URL=http://localhost:3000

# App branding (used in OG tags, wallet passes, and UI)
APP_NAME=LinkHub
APP_DESCRIPTION=Team link profiles.

# ── Database ──────────────────────────────────────────────────────────────────
# MySQL-compatible connection string (PlanetScale, TiDB, or plain MySQL)
DATABASE_URL=mysql://user:password@host:3306/linkhub

# ── Auth & Access ──────────────────────────────────────────────────────────────
# Optional: restrict logins to a single email domain (e.g. "example.com")
# Leave blank to allow any email address.
ALLOWED_EMAIL_DOMAIN=

# Comma-separated emails that are auto-promoted to admin on first login
ADMIN_EMAILS=admin@example.com

# ── Email (magic-link delivery via Resend) ────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
MAILER_FROM=noreply@example.com

# ── File Storage (optional — S3-compatible, for avatar uploads) ───────────────
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=

# ── Apple Wallet (optional) ───────────────────────────────────────────────────
APPLE_WALLET_CERT_P12=
APPLE_WALLET_CERT_PASS=
APPLE_WALLET_PASS_TYPE_ID=
APPLE_WALLET_TEAM_ID=
APPLE_WALLET_WWDR_PEM=
WALLET_LOGO_URL=

# ── Google Wallet (optional) ──────────────────────────────────────────────────
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_SERVICE_ACCOUNT_JSON=

# ── AI / LLM (optional, for AIChatBox feature) ───────────────────────────────
LLM_API_KEY=
LLM_API_URL=
LLM_MODEL=
OPENAI_API_KEY=

# ── Webhooks (optional) ───────────────────────────────────────────────────────
WEBHOOK_NOTIFICATION_URL=
WEBHOOK_NOTIFICATION_SECRET=

# ── Client-side (Vite) ───────────────────────────────────────────────────────
# These are embedded at build time. Set them in .env or export before building.
VITE_APP_NAME=LinkHub
VITE_PUBLIC_BASE_URL=http://localhost:3000
VITE_COMPANY_SLUG=company

# ── Analytics (optional — self-hosted Umami) ─────────────────────────────────
# Uncomment the <script> block in client/index.html to enable.
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
